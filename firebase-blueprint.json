{
  "entities": {
    "sessions": {
      "title": "User Session Log",
      "description": "Captured details about active device contexts viewing the portfolio.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string", "description": "Unique session string" },
        "startTime": { "type": "number", "description": "UTC timestamp of entry session" },
        "lastActive": { "type": "number", "description": "UTC heartbeat of user activity" },
        "browser": { "type": "string", "description": "Interacting browser type" },
        "platform": { "type": "string", "description": "Operating system platform" },
        "screenSize": { "type": "string", "description": "Window dimensions of interface" }
      },
      "required": ["sessionId", "startTime", "lastActive", "browser", "platform"]
    },
    "clicks": {
      "title": "Interactive Click Tracking Log",
      "description": "Records clicking on hyperlinks, action triggers, and project deeper dive toggles.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique click action UUID" },
        "timestamp": { "type": "number", "description": "UTC timestamp of execution" },
        "elementType": { "type": "string", "description": "Hyperlink, Button, or Project Card" },
        "text": { "type": "string", "description": "The textual content of the clicked element" },
        "href": { "type": "string", "description": "The link destination if applicable" },
        "section": { "type": "string", "description": "The structural element or page view context" }
      },
      "required": ["id", "timestamp", "elementType", "text"]
    },
    "sectionViews": {
      "title": "Section Scroll View Tracking Log",
      "description": "Captured views for specific sections in real time.",
      "type": "object",
      "properties": {
        "section": { "type": "string", "description": "The specific scroll section" },
        "timestamp": { "type": "number", "description": "UTC timestamp of the transition" },
        "duration": { "type": "number", "description": "Duration spent on this section in seconds" }
      },
      "required": ["section", "timestamp", "duration"]
    }
  },
  "firestore": {
    "/sessions/{sessionId}": {
      "schema": "sessions",
      "description": "Global user telemetry session logs."
    },
    "/clicks/{clickId}": {
      "schema": "clicks",
      "description": "Unified interaction telemetry events."
    },
    "/sectionViews/{viewId}": {
      "schema": "sectionViews",
      "description": "Micro-sectional dwell actions."
    }
  }
}
